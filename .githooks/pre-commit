#!/bin/bash
# Pre-commit hook to run critical tests before allowing commit
# Install: ./install-hooks.sh

set -e

# Colors
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
NC='\033[0m' # No Color

echo ""
echo "================================================"
echo "  Pre-Commit Test Validation"
echo "================================================"
echo ""

# Check if tests should be skipped
if git rev-parse --verify MERGE_HEAD > /dev/null 2>&1; then
    echo -e "${YELLOW}⚠ Merge commit detected - skipping tests${NC}"
    exit 0
fi

# Allow skipping tests with --no-verify
if [ "$SKIP_TESTS" = "true" ]; then
    echo -e "${YELLOW}⚠ Tests skipped (SKIP_TESTS=true)${NC}"
    exit 0
fi

# Function to run tests
run_tests() {
    echo "🧪 Running critical tests..."
    echo ""

    # Run critical tests
    if ./gradlew testCritical --console=plain 2>&1 | tee /tmp/test-output.txt; then
        echo ""
        echo -e "${GREEN}✅ All critical tests passed!${NC}"
        echo ""
        return 0
    else
        echo ""
        echo -e "${RED}❌ Critical tests failed!${NC}"
        echo ""
        echo "Failed tests:"
        grep "FAILED" /tmp/test-output.txt || echo "See output above"
        echo ""
        echo "Options:"
        echo "  1. Fix the failures and try again"
        echo "  2. Run './run-tests.sh critical' to see detailed output"
        echo "  3. Skip tests with: git commit --no-verify (NOT RECOMMENDED)"
        echo ""
        return 1
    fi
}

# Check for hardcoded paths in staged files
check_hardcoded_paths() {
    echo "🔍 Checking for hardcoded paths..."

    # Get staged Kotlin files
    STAGED_KT_FILES=$(git diff --cached --name-only --diff-filter=ACM | grep "\.kt$" || true)

    if [ -z "$STAGED_KT_FILES" ]; then
        echo "   No Kotlin files staged"
        return 0
    fi

    # Check for hardcoded path
    FOUND=false
    for file in $STAGED_KT_FILES; do
        if grep -q "phone_inbox/agenda.org" "$file" 2>/dev/null; then
            echo -e "${RED}   ❌ Found hardcoded path in: $file${NC}"
            FOUND=true
        fi
    done

    if [ "$FOUND" = true ]; then
        echo ""
        echo -e "${RED}Error: Hardcoded paths detected${NC}"
        echo "Replace 'phone_inbox/agenda.org' with agendaConfigManager.agendaFiles"
        echo ""
        return 1
    fi

    echo -e "${GREEN}   ✓ No hardcoded paths found${NC}"
    return 0
}

# Check for common issues
check_common_issues() {
    echo "🔎 Checking for common issues..."

    # Get staged Kotlin files
    STAGED_KT_FILES=$(git diff --cached --name-only --diff-filter=ACM | grep "\.kt$" || true)

    if [ -z "$STAGED_KT_FILES" ]; then
        echo "   No issues detected"
        return 0
    fi

    ISSUES_FOUND=false

    # Check for println in production code
    for file in $STAGED_KT_FILES; do
        if echo "$file" | grep -vq "/test/" && grep -q "println(" "$file" 2>/dev/null; then
            echo -e "${YELLOW}   ⚠ Found println() in: $file${NC}"
            echo "      Consider using proper logging"
            ISSUES_FOUND=true
        fi
    done

    # Check for TODO comments in staged code
    for file in $STAGED_KT_FILES; do
        if grep -q "// TODO" "$file" 2>/dev/null; then
            echo -e "${YELLOW}   ⚠ Found TODO in: $file${NC}"
            TODO_COUNT=$(grep -c "// TODO" "$file")
            echo "      $TODO_COUNT TODO comment(s) found"
        fi
    done

    if [ "$ISSUES_FOUND" = true ]; then
        echo ""
        echo "Issues detected but not blocking commit"
    fi

    return 0
}

# Main execution
echo "Running pre-commit checks..."
echo ""

# Step 1: Check for hardcoded paths
if ! check_hardcoded_paths; then
    exit 1
fi

echo ""

# Step 2: Check for common issues (non-blocking)
check_common_issues

echo ""

# Step 3: Run critical tests
echo "This may take 30-60 seconds..."
echo ""

if ! run_tests; then
    echo "================================================"
    echo -e "${RED}  Commit blocked by test failures${NC}"
    echo "================================================"
    exit 1
fi

echo "================================================"
echo -e "${GREEN}  All checks passed! Proceeding with commit.${NC}"
echo "================================================"
echo ""

exit 0
